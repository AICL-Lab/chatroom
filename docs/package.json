{
  "name": "chatroom-docs",
  "private": true,
  "type": "module",
  "version": "3.0.0",
  "scripts": {
    "sync": "node scripts/sync-changelog.mjs",
    "docs:dev": "npm run sync && vitepress dev .",
    "docs:build": "npm run sync && vitepress build .",
    "docs:preview": "vitepress preview .",
    "docs:serve": "vitepress serve .",
    "lint:md": "markdownlint-cli2 '**/*.md' --config .markdownlint.json",
    "lint:links": "lychee . --config lychee.toml"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitepress": "^1.6.4"
  },
  "dependencies": {
    "mermaid": "^11.4.0",
    "vitepress-plugin-llms": "^1.0.0",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
